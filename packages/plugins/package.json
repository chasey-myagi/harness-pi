{
  "name": "@harness-pi/plugins",
  "version": "0.2.0",
  "description": "Standard library of harness-pi plugins + controllers + sinks",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chasey-myagi/harness-pi.git",
    "directory": "packages/plugins"
  },
  "homepage": "https://github.com/chasey-myagi/harness-pi/tree/main/packages/plugins#readme",
  "bugs": "https://github.com/chasey-myagi/harness-pi/issues",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./controllers": {
      "types": "./dist/controllers/index.d.ts",
      "default": "./dist/controllers/index.js"
    },
    "./metrics/sinks/memory": {
      "types": "./dist/metrics/sinks/memory.d.ts",
      "default": "./dist/metrics/sinks/memory.js"
    },
    "./metrics/sinks/ndjson-file": {
      "types": "./dist/metrics/sinks/ndjson-file.d.ts",
      "default": "./dist/metrics/sinks/ndjson-file.js"
    },
    "./metrics/sinks/postgres": {
      "types": "./dist/metrics/sinks/postgres.d.ts",
      "default": "./dist/metrics/sinks/postgres.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "!**/__tests__/**",
    "!**/*.test.*"
  ],
  "scripts": {
    "prepublishOnly": "pnpm run build",
    "build": "tsc -p .",
    "typecheck": "tsc -p . --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@harness-pi/core": "workspace:*",
    "@earendil-works/pi-ai": "^0.74.2"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "@types/node": "^22.0.0",
    "pg-mem": "^3.0.14"
  }
}
