{
  "name": "@harness-pi/core",
  "version": "0.2.3",
  "description": "Agent kernel — pi-ai loop + first-class hook system",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chasey-myagi/harness-pi.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/chasey-myagi/harness-pi/tree/main/packages/core#readme",
  "bugs": "https://github.com/chasey-myagi/harness-pi/issues",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "default": "./dist/testing.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "!**/__tests__/**",
    "!**/*.test.*"
  ],
  "scripts": {
    "prepublishOnly": "pnpm run build",
    "build": "tsc -p .",
    "typecheck": "tsc -p . --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.74.2"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "@types/node": "^22.0.0"
  }
}
