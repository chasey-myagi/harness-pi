{
  "name": "@harness-pi/adapters",
  "version": "0.2.1",
  "description": "SessionStore adapters for harness-pi (JSONL file + Postgres). Concrete I/O behind the kernel SessionStore protocol.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chasey-myagi/harness-pi.git",
    "directory": "packages/adapters"
  },
  "homepage": "https://github.com/chasey-myagi/harness-pi/tree/main/packages/adapters#readme",
  "bugs": "https://github.com/chasey-myagi/harness-pi/issues",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "!**/__tests__/**",
    "!**/*.test.*"
  ],
  "scripts": {
    "prepublishOnly": "pnpm run build",
    "build": "tsc -p .",
    "typecheck": "tsc -p . --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@harness-pi/core": "workspace:*",
    "@earendil-works/pi-ai": "^0.74.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "pg": "^8.21.0",
    "pg-mem": "^3.0.14",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
