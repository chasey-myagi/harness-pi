    "@mariozechner/pi-ai": "^0.73.1",
    "@mariozechner/pi-tui": "0.73.1"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "0.73.1",
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
