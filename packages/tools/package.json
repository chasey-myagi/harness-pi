{
  "name": "@harness-pi/tools",
  "version": "0.4.0",
  "description": "First-party coding tools for harness-pi agents",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chasey-myagi/harness-pi.git",
    "directory": "packages/tools"
  },
  "homepage": "https://github.com/chasey-myagi/harness-pi/tree/main/packages/tools#readme",
  "bugs": "https://github.com/chasey-myagi/harness-pi/issues",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "!**/__tests__/**",
    "!**/*.test.*"
  ],
  "scripts": {
    "prepublishOnly": "pnpm run build",
    "build": "tsc -p .",
    "typecheck": "tsc -p . --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@harness-pi/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
