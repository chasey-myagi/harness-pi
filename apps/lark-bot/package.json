    "typecheck": "tsc -p . --noEmit"
  },
  "dependencies": {
    "@harness-pi/core": "workspace:*",
    "@harness-pi/plugins": "workspace:*",
    "@earendil-works/pi-ai": "^0.74.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.6.0"
  }
}
