{
  "name": "@harness-pi/coding-agent",
  "version": "0.3.1",
  "description": "Dogfood coding agent built on harness-pi — usable pi-tui CLI showcasing the harness-pi kernel",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chasey-myagi/harness-pi.git",
    "directory": "apps/coding-agent"
  },
  "homepage": "https://github.com/chasey-myagi/harness-pi/tree/main/apps/coding-agent#readme",
  "bugs": "https://github.com/chasey-myagi/harness-pi/issues",
  "type": "module",
  "main": "./dist/cli.js",
  "types": "./dist/cli.d.ts",
  "bin": {
    "hpi": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/cli.d.ts",
      "default": "./dist/cli.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "!**/__tests__/**",
    "!**/*.test.*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "prepublishOnly": "pnpm run build",
    "start": "tsx src/cli.ts",
    "tui": "tsx src/cli.ts --tui",
    "build": "tsc -p .",
    "typecheck": "tsc -p . --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke:provider": "tsx scripts/d0-smoke.ts"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.74.2",
    "@earendil-works/pi-tui": "0.74.2",
    "@harness-pi/adapters": "workspace:*",
    "@harness-pi/core": "workspace:*",
    "@harness-pi/plugins": "workspace:*",
    "@harness-pi/tools": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
